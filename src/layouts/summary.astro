---
import MainHead from '../components/MainHead.astro';
import SummaryNav from '../components/SummaryNav.astro';
import AnalyticsFooter from '../components/AnalyticsFooter.astro';
import '@fontsource/schibsted-grotesk/400.css';
import '@fontsource/schibsted-grotesk/400-italic.css';
import '@fontsource/schibsted-grotesk/700.css';
import '@fontsource/schibsted-grotesk/700-italic.css';
import '@fontsource/ibm-plex-sans-jp/400.css';
import '@fontsource/ibm-plex-sans-jp/700.css';

const { content } = Astro.props;
---

<html>
<head>
    <MainHead title={content.title} description={content.description} canonicalURL={Astro.request.canonicalURL} />
    <link rel="stylesheet" href="/style/summaries.css">
    <style lang="scss">
      body {
        font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
      }

      .title {
        margin-top: 4rem;
        margin-bottom: 4rem;
        font-size: 3em;
        letter-spacing: -0.04em;
        text-align: center;
        text-wrap: balance;
      }

      .description {
        margin-bottom: 3rem;
        font-size: 1.25em;
        font-weight: 400;
        font-style: italic;
        color: var(--muted);
        line-height: 1.5;
      }

      .img {
        display: block;
        width: 100%;
        height: auto;
      }

      .article {
        margin-top: 4rem;
        margin-bottom: 6rem;
        max-width: 42rem;
        margin-inline: auto;

        :global(p), :global(> ul) {
          line-height: 1.6;
          margin-top: 2em;
          margin-bottom: 2em;
        }
        :global(h3) {
          line-height: 1.2;
          margin-top: 2.5em;
          margin-bottom: 0.75em;
          font-size: 1.65rem;
        }
        :global(li) {
          margin-bottom: 0.6em;
        }
        :global(p), :global(> ul) {
          font-size: 1.3rem;
        }
        :global(li > ul) {
          margin-top: 0.8em;
          margin-bottom: 1.2em;
          font-size: 0.9em;
        }
      }

      .posts {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0.6rem 1.5rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        font-family: var(--font-sans);
        font-size: max(0.85rem, 14px);
        color: var(--accent-text);
      }

      /* QW8: trim dark-mode halation on long-form serif body (keep headings as-is). */
      @media (prefers-color-scheme: dark) {
        .article :global(p),
        .article :global(li) {
          color: #e0dcd7;
          letter-spacing: 0.012em;
        }
      }

      .footer {
        margin-top: 6rem;
        padding-bottom: 6rem;
        text-align: center;
      }
    </style>
</head>

<body>
<SummaryNav />

<main class="wrapper">
    <h2 class="title">{content.title}</h2>
    <p class="description">{content.description}</p>
    <article class="article">
        <slot />
    </article>
    <footer class="footer">
        <a class="posts" href="/summaries">All Summaries</a>
    </footer>
</main>

<footer>
</footer>
</body>
<AnalyticsFooter />
</html>