---
import MainHead from '../../components/MainHead.astro';
import BlogNav from '../../components/BlogNav.astro';
import PostLink from '../../components/PostLink.astro';
import AnalyticsFooter from '../../components/AnalyticsFooter.astro';
import '@fontsource/schibsted-grotesk/700.css';
import '@fontsource/ibm-plex-sans-jp/700.css';

export async function getStaticPaths() {
  let posts = Object.values(import.meta.glob('./*.md', { eager: true }));
  posts = posts.filter((post) => post.frontmatter.subpost !== 'true');
  posts = posts.sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));

  const byDomain = new Map(); // slug -> { label, posts: [] }
  for (const post of posts) {
    const d = post.frontmatter.domain;
    if (!d) continue;
    const slug = String(d).toLowerCase();
    const label = String(d).charAt(0).toUpperCase() + String(d).slice(1);
    if (!byDomain.has(slug)) byDomain.set(slug, { label, posts: [] });
    byDomain.get(slug).posts.push(post);
  }
  return Array.from(byDomain.entries()).map(([slug, { label, posts }]) => ({
    params: { domain: slug },
    props: { label, posts },
  }));
}

const { label, posts } = Astro.props;
const title = `Working Notes: ${label}`;
const description = `Writeups of my current best guesses.`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<html>
<head>
    <MainHead title={title} description={description} canonicalURL={canonicalURL} />
    <link rel="stylesheet" href="/style/blog.css">
    <style lang="scss">
      .title {
        font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
        font-weight: 700;
        font-size: 3em;
        letter-spacing: -0.04em;
        margin-top: 2rem;
        margin-bottom: 0;
        text-align: center;
        color: var(--accent);
      }
      .count {
        font-family: var(--font-sans);
        font-size: max(0.9rem, 14px);
        display: block;
        text-align: center;
        color: var(--muted);
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
      }
    </style>
</head>
<body>
<BlogNav />
<main class="wrapper">
    <h2 class="title">{label}</h2>
    <small class="count">1–{posts.length} of {posts.length}</small>
    {posts.map((post) => <PostLink post={post} />)}
</main>
<footer></footer>
</body>
<AnalyticsFooter />
</html>
