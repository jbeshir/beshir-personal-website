---
import MainHead from '../components/MainHead.astro';
import AnalyticsBody from '../components/AnalyticsBody.astro';
import AnalyticsFooter from '../components/AnalyticsFooter.astro';
import {Image} from "astro:assets";
import avatar from '../assets/avatar.png'
import BotanicalRule from '../components/BotanicalRule.astro';
import '@fontsource/schibsted-grotesk/400.css';
import '@fontsource/schibsted-grotesk/400-italic.css';
import '@fontsource/schibsted-grotesk/700.css';
import '@fontsource/ibm-plex-sans-jp/400.css';
import '@fontsource/ibm-plex-sans-jp/700.css';
---
<!doctype html>
<html lang="en">
<head>
    <MainHead title="JBeshir" description="JBeshir's Personal Site" canonicalURL={Astro.request.url} />

    <link rel="stylesheet" href="/style/home.css">

    <style>
        header {
            display: flex;
            flex-direction: column;
            gap: 1em;
            max-width: min(100%, 68ch);
            margin-bottom: 1.5rem;
        }

        main {
            position: relative;
            max-width: 40rem;
            width: 100%;
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 0;
            clip-path: var(--clip-frame);
            overflow: hidden;
            padding: 2rem 2.5rem 2.5rem;
            box-shadow: var(--shadow-2);
        }

        main::before {
            content: "";
            position: absolute;
            inset: 7px;
            border: 1px solid color-mix(in srgb, var(--border) 50%, transparent);
            clip-path: var(--clip-frame);
            pointer-events: none;
        }

        main::after {
            content: "";
            position: absolute;
            right: -2.5rem;
            bottom: -1.75rem;
            width: 11rem;
            height: 11rem;
            opacity: 0.12;
            pointer-events: none;
            background:
                radial-gradient(circle at 50% 50%, var(--brass) 0 4%, transparent 4.5%),
                conic-gradient(from 22.5deg at 50% 50%, transparent 0 7%, var(--accent) 7.5% 11%, transparent 11.5% 25%);
            clip-path: polygon(50% 0, 61% 34%, 100% 50%, 61% 66%, 50% 100%, 39% 66%, 0 50%, 39% 34%);
        }

        .bio {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-style: italic;
            font-size: 1.2rem;
            line-height: 1.5;
            color: var(--muted);
            text-align: center;
            margin-bottom: 2rem;
        }

        h2 {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-weight: 700;
            color: var(--accent);
            font-size: 1.4rem;
            letter-spacing: 0.01em;
            margin-top: 1.5rem;
            padding-bottom: 0.35rem;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        h2::after {
            content: "◆";
            position: absolute;
            right: 0;
            bottom: -0.45em;
            padding-left: 0.5em;
            background: var(--bg-panel);
            color: var(--brass);
            font-size: 0.5em;
        }

        main > h2:first-of-type {
            margin-top: 0;
        }

        ul {
            list-style: none;
            padding: 0;
            margin-top: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: max(0.5rem, 8px);
        }

        li {
            line-height: 1.45;
        }

        .row {
            display: block;
            position: relative;
            min-height: 2.75rem;
            background: color-mix(in srgb, var(--bg) 78%, transparent);
            border-left: 2px solid var(--border);
            border-bottom: 1px solid color-mix(in srgb, var(--border) 58%, transparent);
            padding: 0.55rem 2.25rem 0.6rem 0.85rem;
            color: var(--fg);
            text-decoration: none;
            text-wrap: pretty;
            transition: border-color 0.15s ease;
        }

        .row:hover {
            border-left-color: var(--accent);
            background: color-mix(in srgb, var(--accent) 5%, var(--bg));
            text-decoration: none;
        }

        .row::after {
            content: "◇";
            position: absolute;
            right: 0.85rem;
            top: 50%;
            color: var(--botanical);
            transform: translateY(-50%);
            transition: color 0.15s ease, transform 0.15s ease;
        }

        .row:hover::after {
            color: var(--accent);
            transform: translate(0.2rem, -50%);
        }

        .row .name {
            color: var(--accent-text);
        }

        .row .desc {
            display: block;
            margin-top: 0.1rem;
            font-family: var(--font-sans);
            font-size: max(0.9rem, 14px);
            color: var(--muted);
        }

        .row:hover .name {
            text-decoration: underline;
            text-underline-offset: 2px;
        }

        .logo {
            font-size: clamp(2rem, -0.4742rem + 6.1856vw, 2.75rem);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.35em;
        }

        .logo > h1 {
            font-size: 1em;
        }

        .logo > img {
            width: 2.4em;
            height: 2.4em;
            border-radius: 50%;
            border: 3px solid var(--accent);
            outline: 1px solid var(--brass);
            outline-offset: 7px;
            box-shadow: 0 6px 20px -6px rgba(40, 20, 10, 0.22);
        }

        .identity-rule {
            width: min(24rem, 82vw);
            margin: -0.8rem auto -0.2rem;
        }

        @media (max-width: 600px) {
            main {
                padding: 1.75rem 1.5rem 2rem;
            }
        }

        /* De-emphasized blocks */
        .japanese {
            margin-top: 1.6rem;
            font-family: var(--font-sans);
            font-size: max(0.9rem, 14px);
            color: var(--muted);
        }

        .japanese a {
            color: var(--muted);
        }

        .japanese a:hover {
            color: var(--accent-text);
        }

        /* Intentional "archive/footer" label: de-emphasised on purpose via an
           uppercase sans treatment (not a lower heading tier). Muted token now
           clears the contrast floor. */
        .archive-heading {
            font-family: var(--font-sans);
            font-size: max(0.85rem, 14px);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            border-bottom-width: 1px;
            color: var(--muted);
        }

        .archive-list {
            font-family: var(--font-sans);
            font-size: max(0.8rem, 14px);
            color: var(--muted);
            gap: 0.2rem;
        }

        .archive-list li {
            padding: 0.18rem 0;
        }

        .archive-list a {
            color: var(--muted);
        }

        .archive-list a:hover {
            color: var(--accent-text);
        }
    </style>
</head>
<body>
    <AnalyticsBody />
    <header>
        <div class="logo">
            <Image width="240" height="240" src={avatar} alt="avatar" />
            <h1>JBeshir</h1>
        </div>
        <div class="identity-rule">
            <BotanicalRule />
        </div>
    </header>
    <main>
        <p class="bio">Software engineer and Giving What We Can member.</p>

        <h2>Writing</h2>
        <ul class="writing-list">
            <li><a class="row" href="/blog"><span class="name">Working Notes</span><span class="desc">Blog on technology, projects, and self-improvement.</span></a></li>
        </ul>

        <h2>Code</h2>
        <ul class="code-list">
            <li><a class="row" href="/projects"><span class="name">Projects</span><span class="desc">Open-source things I build outside of work.</span></a></li>
            <li><a class="row" href="https://github.com/jbeshir/"><span class="name">GitHub</span></a></li>
        </ul>

        <h2>Elsewhere</h2>
        <ul class="elsewhere-list">
            <li><a class="row" href="https://social.beshir.org/jbeshir"><span class="name">@jbeshir@social.beshir.org</span><span class="desc">Follow from any Mastodon or Fediverse account</span></a></li>
            <li><a class="row" href="https://jbeshir.tumblr.com"><span class="name">Tumblr</span></a></li>
            <li><a class="row" href="https://manifold.markets/jbeshir"><span class="name">Manifold Markets</span></a></li>
            <li><a class="row" href="https://www.metaculus.com/accounts/profile/100538/"><span class="name">Metaculus</span></a></li>
            <li><a class="row" href="https://www.goodreads.com/user/show/48821743-john-beshir"><span class="name">Goodreads</span></a></li>
        </ul>

        <p class="japanese">Japanese study: <a href="https://www.wanikani.com/users/JBeshir">WaniKani</a> · <a href="https://bunpro.jp/share/JBeshir">Bunpro</a></p>

        <h2>Volunteering</h2>
        <ul class="volunteering-list">
            <li><a class="row" href="https://www.vox.com/future-perfect/2019/2/21/18235136/vaccine-malaria-research-trials-volunteers"><span class="name">Vox: Malaria Challenge Trial</span></a></li>
        </ul>

        <h2>Contests</h2>
        <ul class="contest-list">
            <li><a class="row" href="https://www.gileadlab.net/2020-insight-leaderboard.html"><span class="name">Top 20% In Metaculus 20/20 Insight Forecasting Contest</span></a></li>
        </ul>

        <h2 class="archive-heading">Archive</h2>
        <ul class="archive-list">
            <li><a href="/summaries">Overly Short Summaries</a>: older, archived experimental reading-aid summaries of things I’ve read.</li>
        </ul>
    </main>
</body>
<AnalyticsFooter />
</html>
