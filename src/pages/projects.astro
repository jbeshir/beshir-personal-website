---
import MainHead from '../components/MainHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import AnalyticsFooter from '../components/AnalyticsFooter.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import FeaturedMediaCard from '../components/FeaturedMediaCard.astro';
import { getImage } from "astro:assets";
import jvtLight from '../assets/projects/japanese-verb-tower-light.jpg';
import jvtDark from '../assets/projects/japanese-verb-tower-dark.jpg';
import pennsicLight from '../assets/projects/pennsic-planner-light.jpg';
import pennsicDark from '../assets/projects/pennsic-planner-dark.jpg';
import glowficlogLight from '../assets/projects/glowficlog-light.jpg';
import glowficlogDark from '../assets/projects/glowficlog-dark.jpg';
import { widgets, mcpServers } from '../data/projects.js';
import '@fontsource/schibsted-grotesk/400.css';
import '@fontsource/schibsted-grotesk/400-italic.css';
import '@fontsource/schibsted-grotesk/700.css';
import '@fontsource/ibm-plex-sans-jp/400.css';
import '@fontsource/ibm-plex-sans-jp/700.css';

const sources = {
    'japanese-verb-tower': { light: jvtLight, dark: jvtDark },
    'pennsic-planner': { light: pennsicLight, dark: pennsicDark },
};

const imgMap = {};
for (const [slug, pair] of Object.entries(sources)) {
    const height = Math.round(640 * pair.light.height / pair.light.width);
    imgMap[slug] = {
        light: await getImage({ src: pair.light, width: 640, height }),
        dark: await getImage({ src: pair.dark, width: 640, height }),
        width: 640,
        height,
    };
}
---
<!doctype html>
<html lang="en">
<head>
    <MainHead title="Projects" description="Open-source projects I build outside of work." canonicalURL={Astro.request.url} />

    <style>
        main {
            max-width: 52rem;
            width: 100%;
            margin: 0 auto;
            padding: 2.5rem 1.5rem 4rem;
        }

        h1 {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-weight: 700;
            color: var(--accent);
            font-size: 2.2rem;
            letter-spacing: -0.02em;
            margin-bottom: 0.5rem;
        }

        .intro {
            color: var(--muted);
            margin-bottom: 2.5rem;
            line-height: 1.6;
        }

        h2 {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-weight: 700;
            color: var(--accent);
            font-size: 1.5rem;
            letter-spacing: 0.01em;
            margin-top: 2.5rem;
            margin-bottom: 0.75rem;
            padding-bottom: 0.25rem;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        h2::after {
            content: "✦";
            position: absolute;
            right: 0;
            bottom: -0.6em;
            padding-left: 0.6em;
            background: var(--bg);
            color: var(--brass);
            font-size: 0.55em;
        }

        .section-intro {
            margin-bottom: 1.25rem;
            line-height: 1.6;
        }

        /* Featured card */
        .card-title {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-weight: 700;
            color: var(--accent);
            font-size: 1.6rem;
            margin-top: 0;
            margin-bottom: 0.6rem;
            border-bottom: none;
            padding-bottom: 0;
        }

        /* Widget cards */
        .widget-grid {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            margin-bottom: 1rem;
        }

        .widget-card {
            position: relative;
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 0;
            clip-path: var(--clip-frame);
            box-shadow: var(--shadow-1);
            overflow: hidden;
            display: flex;
            flex-direction: row;
            gap: 0;
            color: var(--fg);
            text-decoration: none;
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        }

        .widget-card::after {
            content: "";
            position: absolute;
            inset: 6px;
            border: 1px solid color-mix(in srgb, var(--border) 42%, transparent);
            clip-path: var(--clip-frame);
            pointer-events: none;
        }

        .widget-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-2);
            border-color: var(--accent);
            text-decoration: none;
        }

        .widget-card:hover .widget-title {
            text-decoration: underline;
            text-underline-offset: 2px;
        }

        .widget-img {
            flex: 0 0 200px;
            overflow: hidden;
        }

        .widget-img picture {
            display: block;
            width: 100%;
            height: 100%;
        }

        .widget-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            border-radius: 0;
        }

        .widget-body {
            padding: 1.5rem 1.75rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .widget-title {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-weight: 700;
            color: var(--accent);
            font-size: 1.15rem;
            margin-bottom: 0.4rem;
        }

        .more-link {
            font-family: var(--font-sans);
            font-size: max(0.9rem, 14px);
            color: var(--muted);
            margin-top: 0.5rem;
        }

        .more-link a {
            display: inline-flex;
            align-items: center;
            min-height: 44px;
            color: var(--accent-text);
        }

        .more-link a:hover {
            color: var(--accent-text);
            text-decoration: underline;
            text-underline-offset: 2px;
        }

        /* MCP list */
        .mcp-list {
            list-style: none;
            margin: 0;
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 0;
            clip-path: var(--clip-frame);
            box-shadow: var(--shadow-1);
            padding: 0.5rem 1.5rem;
        }

        .mcp-list li {
            padding: 0.75rem 0;
            line-height: 1.5;
            border-bottom: 1px solid var(--border);
        }

        .mcp-list li:last-child {
            border-bottom: none;
        }

        @media (max-width: 600px) {
            main {
                padding: 1.5rem 1rem 3rem;
            }

            .widget-card {
                flex-direction: column;
            }

            .widget-img {
                flex: none;
                height: 180px;
            }

            .widget-body {
                padding: 1.25rem 1.25rem;
            }
        }
    </style>
</head>
<body>
    <SiteHeader title="Projects" subtitle="Open-source projects I build outside of work." href="/projects" />
    <main>
        <div class="intro">
            <p>Mostly small tools, made for my own use and shared in case they're useful.</p>
        </div>

        <FeaturedCard href="https://github.com/jbeshir/demesne">
            <h3 class="card-title">demesne</h3>
            <p>A sandbox for running containerised local AI agent pipelines and ad-hoc code with controlled network access, exposed over MCP. I built it to run my own agent workflows to accomplish larger tasks safely and to higher quality.</p>
        </FeaturedCard>

        <FeaturedMediaCard
            href="https://github.com/jbeshir/glowficlog"
            lightSrc={glowficlogLight}
            darkSrc={glowficlogDark}
            imageWidth={520}
            imageAlt="The glowficlog reader showing a condensed glowfic thread"
        >
            <h3 class="card-title">glowficlog</h3>
            <p>A browser extension that reformats glowfic.com thread pages into a compact, high-density reader, collapsing endless one-post-per-line forum formatting into a continuous, novel-like column with alternating gutter icons.</p>
        </FeaturedMediaCard>

        <h2>Widgets</h2>
        <p class="section-intro">Small embeddable widgets, each deployed on its own subdomain under widgets.beshir.org. <a href="https://github.com/jbeshir/beshir-widgets">See the repo</a>.</p>

        <div class="widget-grid">
            {widgets.map((w) => (
                <a class="widget-card" href={w.url}>
                    <div class="widget-img">
                        <picture>
                            <source srcset={imgMap[w.image].dark.src} media="(prefers-color-scheme: dark)" />
                            <img src={imgMap[w.image].light.src} alt={w.title} loading="lazy" width={imgMap[w.image].width} height={imgMap[w.image].height} />
                        </picture>
                    </div>
                    <div class="widget-body">
                        <p class="widget-title">{w.title}</p>
                        <p>{w.blurb}</p>
                    </div>
                </a>
            ))}
        </div>
        <p class="more-link"><a href="/widgets">All widgets →</a></p>

        <h2>MCP servers</h2>
        <p class="section-intro">A handful of small MCP servers, mostly so an assistant can read from services I use. <a href="https://github.com/jbeshir/mcp-servers">See the repo</a>.</p>
        <ul class="mcp-list">
            {mcpServers.map((s) => (
                <li><strong>{s.name}</strong> — {s.blurb}</li>
            ))}
        </ul>
    </main>
</body>
<AnalyticsFooter />
</html>
