---
import MainHead from '../components/MainHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import AnalyticsFooter from '../components/AnalyticsFooter.astro';
import WidgetEmbed from '../components/WidgetEmbed.astro';
import widgets from '../data/widgets.json';
import '@fontsource/schibsted-grotesk/400.css';
import '@fontsource/schibsted-grotesk/400-italic.css';
import '@fontsource/schibsted-grotesk/700.css';
import '@fontsource/ibm-plex-sans-jp/400.css';
import '@fontsource/ibm-plex-sans-jp/700.css';

const embedOverrides = {
    'pennsic-planner': 'https://pennsic-planner.widgets.beshir.org/#/c/o7lUWqX3FUlMA5wEyf7B_w',
};
---
<!doctype html>
<html lang="en">
<head>
    <MainHead title="Widgets" description="Small embeddable widgets, each on its own subdomain." canonicalURL={Astro.request.url} />

    <style>
        main {
            max-width: 56rem;
            width: 100%;
            margin: 0 auto;
            padding: 2.5rem 1.5rem 4rem;
        }

        h1 {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-weight: 700;
            color: var(--accent);
            font-size: 2.2rem;
            letter-spacing: -0.02em;
            margin-bottom: 0.5rem;
        }

        .intro {
            color: var(--muted);
            margin-bottom: 2.5rem;
            line-height: 1.6;
        }

        .widget-list {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .widget-card {
            background: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 0;
            box-shadow: var(--shadow-1);
            padding: 2rem 2.5rem;
        }

        .card-title {
            font-family: 'Schibsted Grotesk', 'IBM Plex Sans JP', sans-serif;
            font-weight: 700;
            color: var(--accent);
            font-size: 1.5rem;
            margin-top: 0;
            margin-bottom: 0.5rem;
        }

        .card-title a {
            color: var(--accent);
            text-decoration: none;
        }

        .card-title a:hover {
            text-decoration: underline;
            text-underline-offset: 2px;
        }

        .card-desc {
            color: var(--fg);
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .view-link {
            font-family: var(--font-sans);
            font-size: max(0.9rem, 14px);
            margin-bottom: 0.75rem;
        }

        .view-link a {
            display: inline-flex;
            align-items: center;
            min-height: 44px;
        }

        @media (max-width: 600px) {
            main {
                padding: 1.5rem 1rem 3rem;
            }

            .widget-card {
                padding: 1.5rem 1.5rem;
            }
        }
    </style>
</head>
<body>
    <SiteHeader title="Widgets" subtitle="Small embeddable widgets, each on its own subdomain." href="/widgets" />
    <main>
        <p class="intro">Live previews below — each is also embeddable in a page via its iframe. <a href="https://github.com/jbeshir/beshir-widgets">See the repo</a>.</p>

        <div class="widget-list">
            {widgets.map((w) => {
                const embedUrl = embedOverrides[w.slug] ?? w.url;
                return (
                <div class="widget-card botanical-frame">
                    <h2 class="card-title"><a href={w.url}>{w.title}</a></h2>
                    <p class="card-desc">{w.description}</p>
                    <p class="view-link"><a href={embedUrl}>View full page →</a></p>
                    <WidgetEmbed slug={w.slug} height={w.embedHeight} title={w.title} src={embedUrl} />
                </div>
                );
            })}
        </div>
    </main>
</body>
<AnalyticsFooter />
</html>
