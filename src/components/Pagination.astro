---
const { nextUrl, prevUrl } = Astro.props;
---

<style lang="scss">
  .nav {
    display: flex;
    padding-top: 2.5rem;
    padding-bottom: 4rem;
    border-top: 1px solid var(--border);
    margin-top: 1rem;
  }

  .prev,
  .next {
    flex: 1;
    display: block;
    padding: 0.75rem 1.5rem;
    text-transform: uppercase;
    text-align: center;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.05em;
    font-size: 0.85rem;

    &:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    &[href="#"] {
      display: none;
    }
  }

  .prev {
    margin-right: auto;
  }

  .next {
    margin-left: auto;
  }
</style>

<div class="wrapper">
    <nav class="nav">
        <a class="prev" href={prevUrl || '#'} aria-label="Previous Page">Prev Page</a>
        <a class="next" href={nextUrl || '#'} aria-label="Next Page">Next Page</a>
    </nav>
</div>