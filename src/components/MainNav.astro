---
import AnalyticsBody from './AnalyticsBody.astro';
import { Image } from 'astro:assets'
import avatar from '../assets/avatar.png'
---
<style>
  .logo, .logo * {
      display: inline-block;
      vertical-align: middle;
   }
  .logo {
      margin: 0.5em 3em;
  }
  .logo a {
      text-decoration: none;
      color: inherit;
  }
  .logo a h1 {
      transition: color 0.18s ease;
  }
  .logo img {
    margin-right: 1em;
    border-radius: 50%;
    box-shadow:
      0 0 0 2px var(--accent),
      0 0 0 5px var(--bg-panel),
      0 0 0 6px var(--brass);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .logo a:hover h1 {
    color: var(--accent);
  }
  .logo a:hover img {
    transform: translateY(-2px);
    box-shadow:
      0 0 0 2px var(--accent),
      0 0 0 5px var(--bg-panel),
      0 0 0 6px var(--brass),
      0 8px 16px -6px rgba(40, 20, 10, 0.4);
  }
</style>

<AnalyticsBody />
<div class="logo">
    <a href="/">
        <Image width="60" height="60" src={avatar} alt="avatar" />
        <h1>JBeshir</h1>
    </a>
</div>
