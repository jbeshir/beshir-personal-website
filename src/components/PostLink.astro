---
import TopicTags from './TopicTags.astro';

const { author, post } = Astro.props;

function formatDate(date) {
return new Date(date).toUTCString().replace(/(\d\d\d\d) .*/, '$1'); // remove everything after YYYY
}
---

<style lang="scss">
  .post-entry {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow-1);
    padding: 1.75rem 2rem;
    margin: 1.5rem 0;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .post-entry:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-2);
    border-color: var(--accent);
  }

  .post {
    display: block;
    text-align: center;
    color: inherit;
    text-decoration: none;
    width: 100%;
  }

  .date {
    font-family: var(--font-sans);
    font-size: max(0.9rem, 14px);
    font-style: italic;
    color: var(--muted);
  }

  .description {
    font-size: 1em;
    color: var(--fg);
    margin-top: 0.5em;
  }

  h2 {
    font-weight: 700;
    font-size: 2em;
    line-height: 1.15;
    letter-spacing: -0.04em;
    text-wrap: balance;
    margin-top: 0;
    margin-bottom: 0;
    color: var(--accent);
  }

  time {
    display: block;
    margin-top: 0.25rem;
    margin-bottom: 0.5em;
  }

</style>

<div class="post-entry">
<a class="post" href={post.url}>

    <div class="data">
        <h2>{post.frontmatter.title}</h2>
        <time class="date" datetime={post.frontmatter.date}>{formatDate(post.frontmatter.date)}</time>
        <p class="description">
            {post.frontmatter.description}
        </p>
    </div>
</a>
<TopicTags categories={post.frontmatter.categories} domain={post.frontmatter.domain} />
</div>
