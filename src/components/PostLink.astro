---
import TopicTags from './TopicTags.astro';

const { author, post } = Astro.props;

function formatDate(date) {
return new Date(date).toUTCString().replace(/(\d\d\d\d) .*/, '$1'); // remove everything after YYYY
}
---

<style lang="scss">
  .post-entry {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post {
    display: block;
    text-align: center;
    color: inherit;
    text-decoration: none;
    width: 100%;
  }

  .date {
    font-style: italic;
    color: var(--muted);
  }

  .description {
    font-size: 1.25em;
    color: var(--fg);
    margin-top: 0.5em;
  }

  h2 {
    font-weight: 700;
    font-size: 2em;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-top: 0;
    margin-bottom: 0;
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }

  time {
    display: block;
    margin-top: 0.25rem;
    margin-bottom: 0.5em;
  }

</style>

<div class="post-entry">
<a class="post" href={post.url}>

    <div class="data">
        <h2>{post.frontmatter.title}</h2>
        <time class="date" datetime={post.frontmatter.date}>{formatDate(post.frontmatter.date)}</time>
        <p class="description">
            {post.frontmatter.description}
        </p>
    </div>
</a>
<TopicTags categories={post.frontmatter.categories} />
</div>
