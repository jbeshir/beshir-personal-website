---
const { title } = Astro.props;

import MainNav from './MainNav.astro';
---

<style lang="scss">
  .header {
    text-align: center;

    @media (min-width: 600px) {
      display: flex;
      align-items: center;
      padding: 2rem;
    }
  }

  .title-block {
    display: block;
    flex: 1;
    padding: 1em;
    color: inherit;
    text-decoration: none;
  }

  .title {
    font-family: 'Spectral', serif;
    font-size: 1.3em;
    letter-spacing: -0.03em;
    font-weight: 700;
    color: var(--accent);
    margin: 0;
  }

  .subtitle {
    font-size: 0.85em;
    color: var(--muted);
    margin-top: 0.2em;
  }
</style>

<nav class="header">
    <MainNav />
    <a class="title-block" href="/blog">
      <h1 class="title">Blog</h1>
      <div class="subtitle">Writing on technology, self-improvement, and rationality.</div>
    </a>
</nav>